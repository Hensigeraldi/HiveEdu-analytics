# ============================================
# HiveEdu E-Raport — Local Environment Config
# ============================================
# Copy this file to .env and fill in your values.

# PostgreSQL Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password_here
DB_NAME=hiveedu_eraport

# JWT Authentication
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=1d

# Application
APP_PORT=3000
APP_ENV=development
